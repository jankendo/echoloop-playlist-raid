{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "echoloop/manifest.schema.json",
  "type": "object",
  "required": ["schema_version", "title", "duration_ms"],
  "properties": {
    "schema_version": {"type": "integer", "enum": [1, 2]},
    "song_id": {"type": "string", "minLength": 1},
    "song_uuid": {"type": "string", "minLength": 1},
    "song_id": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "artist": {"type": "string"},
    "duration_ms": {"type": "integer", "minimum": 1},
    "audio_file": {"type": "string", "minLength": 1},
    "chart_file": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "source": {
      "oneOf": [
        {"type": "string"},
        {
          "type": "object",
          "properties": {
            "source_type": {"type": "string"},
            "extractor": {"type": "string"},
            "source_id": {"type": "string"},
            "title": {"type": "string"},
            "artist": {"type": "string"},
            "channel": {"type": "string"},
            "uploader": {"type": "string"},
            "duration_seconds": {"type": "number", "minimum": 0},
            "upload_date": {"type": "string"},
            "webpage_url": {"type": "string"},
            "thumbnail": {"type": "string"},
            "availability": {"type": "string"},
            "live_status": {"type": "string"},
            "playlist_id": {"type": "string"},
            "playlist_title": {"type": "string"},
            "playlist_index": {"type": ["integer", "null"], "minimum": 1}
          },
          "additionalProperties": false
        }
      ]
    },
    "audio_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "bpm": {"type": "number", "minimum": 0},
    "artist": {"type": "string"},
    "backend": {"type": "string"},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "chart_difficulties": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
