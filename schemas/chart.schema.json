{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "echoloop/chart.schema.json",
  "type": "object",
  "required": ["schema_version", "chart_id", "duration_ms", "phrases", "notes"],
  "properties": {
    "schema_version": {"type": "integer", "enum": [1, 2]},
    "chart_id": {"type": "string", "minLength": 1},
    "song_uuid": {"type": "string"},
    "difficulty": {"type": "string", "enum": ["easy", "normal", "hard", "expert"]},
    "generator_version": {"type": "string"},
    "seed": {"type": ["integer", "string"]},
    "bpm": {"type": "number", "exclusiveMinimum": 0},
    "beats_per_bar": {"type": "integer", "minimum": 1, "maximum": 12},
    "duration_ms": {"type": "integer", "minimum": 1},
    "timing": {"$ref": "#/$defs/timing"},
    "phrases": {"type": "array", "minItems": 1},
    "sections": {"type": "array"},
    "notes": {"type": "array", "items": {"$ref": "#/$defs/note"}},
    "boss": {"type": "object"},
    "quality": {"type": "object"}
  },
  "allOf": [
    {
      "if": {"properties": {"schema_version": {"const": 1}}},
      "then": {"required": ["seed", "bpm", "beats_per_bar"]}
    },
    {
      "if": {"properties": {"schema_version": {"const": 2}}},
      "then": {"required": ["song_uuid", "difficulty", "generator_version", "seed", "timing"]}
    }
  ],
  "$defs": {
    "note": {
      "type": "object",
      "required": ["id", "type", "lane", "time_ms", "phrase"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "type": {"type": "string", "enum": ["tap", "hold", "chord"]},
        "lane": {"type": "integer", "minimum": 0, "maximum": 3},
        "lanes": {"type": "array", "items": {"type": "integer", "minimum": 0, "maximum": 3}, "minItems": 2, "maxItems": 4},
        "time_ms": {"type": "integer", "minimum": 0},
        "duration_ms": {"type": "integer", "minimum": 0},
        "phrase": {"type": "integer", "minimum": 0},
        "accent": {"type": "boolean"},
        "section": {"type": "string"},
        "original_time_ms": {"type": "number"},
        "beat_position": {"type": "number"},
        "quantization_error_ms": {"type": "number"},
        "source": {"type": "string"},
        "confidence": {"type": "number"},
        "weight": {"type": "number"}
      },
      "additionalProperties": true
    },
    "timing": {
      "type": "object",
      "properties": {
        "bpm_summary": {"type": "number", "exclusiveMinimum": 0},
        "beats_per_bar": {"type": "integer", "minimum": 1, "maximum": 12},
        "beats_ms": {"type": "array", "items": {"type": "number"}},
        "downbeats_ms": {"type": "array", "items": {"type": "number"}},
        "tempo_segments": {"type": "array"},
        "audio_offset_ms": {"type": "number"}
      },
      "required": ["bpm_summary", "beats_per_bar", "beats_ms", "downbeats_ms"]
    }
  },
  "additionalProperties": false
}
