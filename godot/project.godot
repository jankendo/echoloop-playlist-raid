; ECHOLOOP: PLAYLIST RAID — Godot 4.7.1 Standard
config_version=5

[application]
config/name="ECHOLOOP: PLAYLIST RAID"
config/description="ローカル音源とYouTube音声を解析して遊ぶ、F/J DUO対応リズム・ローグライト"
config/icon="res://icon.svg"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[autoload]
AppState="*res://autoload/app_state.gd"
SaveService="*res://autoload/save_service.gd"
LogService="*res://autoload/log_service.gd"
SettingsService="*res://autoload/settings_service.gd"
AudioClock="*res://autoload/audio_clock.gd"
InputTiming="*res://autoload/input_timing.gd"
Accessibility="*res://autoload/accessibility.gd"
VersionService="*res://autoload/version_service.gd"
SongLibrary="*res://autoload/song_library.gd"
JobService="*res://autoload/job_service.gd"

[display]
window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0.02, 0.03, 0.08, 1)

[audio]
driver/enable_input=false
